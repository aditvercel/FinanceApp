# ─── Groq API (replaces Anthropic Claude) ───
GROQ_API_KEY=gsk_your_groq_api_key_here

# Chat model (https://console.groq.com/docs/models)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview

# Tuning
GROQ_MAX_TOKENS=2048
GROQ_SYSTEM_PROMPT="You are a helpful assistant for FinanceApp."
GROQ_TIMEOUT_MS=30000

# ─── Currency Exchange (for receipt scan) ───
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# If using the new Supabase publishable key format, use this instead:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Cron (Vercel) ───
CRON_SECRET=your_cron_secret
